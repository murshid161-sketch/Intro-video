<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Raouf & Asna | Wedding Invitation</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,400;1,600&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
html,body{width:100%;height:100%;overflow:hidden}

/* ── LANDING SCREEN ── */
#landing{
  position:fixed;inset:0;z-index:9999;
  display:flex;flex-direction:column;
  align-items:center;justify-content:center;
  overflow:hidden;
  cursor:pointer;
}
#landing-gif{
  position:absolute;inset:0;width:100%;height:100%;
  object-fit:cover;object-position:center;
  display:block;
}
/* dark vignette */
#landing::after{
  content:'';position:absolute;inset:0;
  background:radial-gradient(ellipse at center,rgba(0,0,0,.08) 0%,rgba(0,0,0,.45) 100%);
  pointer-events:none;
}
.tap-content{
  position:relative;z-index:2;
  text-align:center;
  animation:floatUp 3s ease-in-out infinite;
}
@keyframes floatUp{
  0%,100%{transform:translateY(0)}
  50%{transform:translateY(-10px)}
}
.tap-label{
  font-family:'Cormorant Garamond',serif;
  font-size:.7rem;letter-spacing:.35em;text-transform:uppercase;
  color:rgba(255,255,255,.7);margin-bottom:18px;
}
.tap-circle{
  width:100px;height:100px;
  border-radius:50%;
  border:1.5px solid rgba(255,255,255,.5);
  display:flex;align-items:center;justify-content:center;
  margin:0 auto 18px;
  position:relative;
  backdrop-filter:blur(2px);
  background:rgba(255,255,255,.08);
}
.tap-circle::before{
  content:'';position:absolute;inset:-8px;
  border-radius:50%;
  border:1px solid rgba(255,255,255,.2);
  animation:ripple 2.2s ease-out infinite;
}
.tap-circle::after{
  content:'';position:absolute;inset:-18px;
  border-radius:50%;
  border:1px solid rgba(255,255,255,.1);
  animation:ripple 2.2s ease-out infinite .5s;
}
@keyframes ripple{
  0%{transform:scale(1);opacity:.6}
  100%{transform:scale(1.4);opacity:0}
}
.tap-icon{font-size:2.4rem}
.tap-text{
  font-family:'Cormorant Garamond',serif;
  font-size:1.5rem;font-style:italic;font-weight:300;
  color:#fff;letter-spacing:.05em;
}
.tap-names{
  font-family:'Cormorant Garamond',serif;
  font-size:2.6rem;font-style:italic;font-weight:300;
  color:#fff;margin-top:6px;
  text-shadow:0 2px 20px rgba(0,0,0,.4);
}

/* ── OPEN ANIMATION ── */
#landing.opening{
  animation:sealBreak .9s cubic-bezier(.4,0,.2,1) forwards;
}
@keyframes sealBreak{
  0%{opacity:1;transform:scale(1)}
  40%{transform:scale(1.04)}
  100%{opacity:0;transform:scale(1.1);pointer-events:none}
}

/* ── INVITE WRAPPER ── */
#invite-wrap{
  position:fixed;inset:0;z-index:1;
  overflow-y:auto;overflow-x:hidden;
  opacity:0;transform:translateY(30px);
  transition:opacity .7s ease .3s, transform .7s ease .3s;
  pointer-events:none;
}
#invite-wrap.visible{
  opacity:1;transform:translateY(0);
  pointer-events:all;
}
#invite-frame{
  width:100%;min-height:100%;
  border:none;display:block;
}
</style>
</head>
<body>

<!-- LANDING -->
<div id="landing" onclick="openInvite()">
  <img id="landing-gif" src="data:image/gif;base64,
" alt="wedding">
  <div class="tap-content">
    <div class="tap-label">You are cordially invited</div>
    <div class="tap-circle">
      <span class="tap-icon">💌</span>
    </div>
    <div class="tap-text">Tap to Open</div>
    <div class="tap-names">Raouf &amp; Asna</div>
  </div>
</div>

<!-- INVITATION (loaded inline as srcdoc) -->
<div id="invite-wrap">
  <iframe id="invite-frame" srcdoc="" scrolling="yes"></iframe>
</div>

<script>
var opened = false;
function openInvite() {
  if (opened) return;
  opened = true;
  var landing = document.getElementById('landing');
  landing.classList.add('opening');
  // Load invitation into iframe
  var frame = document.getElementById('invite-frame');
  var wrap = document.getElementById('invite-wrap');
  frame.srcdoc = atob('');
  setTimeout(function() {
    wrap.classList.add('visible');
    document.body.style.overflow = 'auto';
  }, 600);
  setTimeout(function() {
    landing.style.display = 'none';
  }, 1200);
}
</script>
</body>
</html>
